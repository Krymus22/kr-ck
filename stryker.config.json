{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker mutation testing configuration. Run with: npx stryker run",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/apiClient.ts",
    "src/heartbeat.ts",
    "src/apiKeyPool.ts",
    "src/searxManager.ts",
    "src/extensions.ts",
    "src/agent.ts",
    "src/history.ts",
    "src/researchHint.ts",
    "src/robloxMcpGuard.ts",
    "src/llmCompactor.ts",
    "src/autoMemory.ts",
    "src/contextCompaction.ts",
    "src/argsNormalizer.ts",
    "src/fileEdit.ts",
    "src/impactAnalyzer.ts",
    "src/bugHunter.ts",
    "src/dataGuard.ts",
    "src/modes.ts",
    "src/toolDetector.ts",
    "src/testRunner.ts",
    "src/invariants.ts",
    "src/i18n.ts",
    "src/utf8Safety.ts",
    "src/toolInstaller.ts",
    "src/toolUpdater.ts",
    "src/modeExtensions.ts",
    "src/externalTools.ts",
    "src/honestySystem.ts",
    "src/subAgents.ts",
    "src/lspAst.ts",
    "src/manifestLoader.ts",
    "src/fileFinder.ts",
    "src/rollbackStore.ts",
    "src/taskState.ts",
    "src/importResolver.ts",
    "src/effortLevels.ts",
    "src/configSchema.ts",
    "src/fileValidator.ts",
    "src/thinkTool.ts",
    "src/pokaYoke.ts",
    "src/strictQualityGate.ts",
    "src/guardrail.ts",
    "src/contentSearch.ts",
    "src/fileSearch.ts",
    "src/shell.ts",
    "src/tools.ts",
    "src/diffPreview.ts",
    "src/sideBySideDiff.ts",
    "src/syntaxHighlight.ts",
    "src/streaming.ts",
    "src/clipboard.ts",
    "src/dotfileConfig.ts",
    "src/configSeeder.ts",
    "src/hookRunner.ts",
    "src/todos.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "timeoutMS": 60000,
  "timeoutFactor": 2,
  "maxTestRunnerReuse": 5,
  "concurrency": 4,
  "ignoreStatic": true,
  "vitest": {
    "configFile": "vitest.config.ts"
  }
}
