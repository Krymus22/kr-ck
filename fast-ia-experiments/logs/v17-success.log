```lua
local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local Cache
local DataStore
local AutoSaveThread
local IsShutDown = false

local function GenerateGuid()
	return HttpService:GenerateGuid()
end

local defaultData = {} -- Defined as needed by implementation

local PlayerDataManager = {}
function PlayerDataManager.new(dataStoreName)
	DataStore = DataStoreService:GetDataStore(dataStoreName)
	Cache = {}
	IsShutDown = false

	local self = {}

function self.loadPlayer(player)
		if player == nil then
			error("Player is nil")
			return false
		end

		local userId = player.UserId
		local newSessionId = GenerateGuid()

		local success, result = pcall(function()
			return DataStore:UpdateAsync(userId, function(oldData)
				if not oldData then
					return {data = table.clone(defaultData), sessionId = newSessionId, version = 1}
				end

				if oldData.sessionId ~= newSessionId then
					-- If the session is different, we allow the overwrite to prevent deadlocks
					-- caused by crashes or unexpected disconnect.
					return {data = oldData.data, sessionId = newSessionId, version = oldData.version + 1}
				end

				return {data = oldData.data, sessionId = newSessionId, version = oldData.version + 1}
			end)
		end)

		if success then
			Cache[userId] = result
			return true, result
		else
			error("Connection error: " .. tostring(result))
			return false
		end
	end

	function self.savePlayer(player)
		local userId = player.UserId
		local cachedData = Cache[userId]

		if not cachedData then
			error("Player não carregado")
			return false
		end

		local attempts = 0
		local maxRetries = 3

		while attempts < maxRetries do
			local success, result = pcall(function()
				return DataStore:UpdateAsync(userId, function(oldData)
					if oldData and oldData.sessionId ~= cachedData.sessionId then
						error("Session Lock Violation: Dados alterados externamente")
					end

					return {
						data = cachedData.data,
						sessionId = cachedData.sessionId,
						version = (oldData and oldData.version or 0) + 1
					}
				end)
			end)

			if success then
				cachedData.version = result.version
				return true
			else
				attempts = attempts + 1
				task.wait(math.pow(2, attempts))
			end
		end

		error("Falha crítica após tentativas")
		return false
	end

	function self.unloadPlayer(player)
		local userId = player.UserId
		self.savePlayer(player)
		Cache[userId] = nil
	end

	function self.startAutoSave(interval)
		if AutoSaveThread then
			task.cancel(AutoSaveThread)
		end

		AutoSaveThread = task.spawn(function()
			while not IsShutDown do
					task.wait(interval)
				for userId, _ in pairs(Cache) do
					local player = Players:GetPlayerByUserId(userId)
					if player then
						self.savePlayer(player)
					end
				end
			end
		end)
	end

	function self.stopAutoSave()
		IsShutDown = true
		if AutoSaveThread then
			task.cancel(AutoSaveThread)
		end
	end

function self.saveAll()
		IsShutDown = true
		self.stopAutoSave()
		for userId, _ in pairs(Cache) do
			local player = Players:GetPlayerByUserId(userId)
			if player then
				pcall(function()
					self.savePlayer(player)
				end)
			end
		end
		IsShutDown = false
	end

return PlayerDataManager
```
