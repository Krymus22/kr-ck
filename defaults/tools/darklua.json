[
  {
    "name": "darklua_process",
    "description": "Process/transform Luau scripts with DarkLua (minify, rewrite requires, etc.)",
    "category": "roblox",
    "command": "darklua",
    "args": ["process"],
    "flags": [
      { "name": "--apply", "type": "boolean", "description": "Apply transformations in-place" },
      { "name": "input", "type": "string", "required": true, "description": "Input file or directory" },
      { "name": "output", "type": "string", "description": "Output file or directory" }
    ],
    "detection": { "method": "binary", "check": "darklua --version" },
    "context": {
      "whenToUse": ["minify luau", "transform luau", "darklua", "bundle roblox", "rewrite requires"],
      "examples": ["darklua process src/ dist/", "darklua process --apply script.luau"]
    },
    "outputParser": "raw"
  }
]
