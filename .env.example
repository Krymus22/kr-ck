# ─── Required: API Provider ─────────────────────────────────────────────────
# Choose your API provider: NVIDIA NIM (default) or ZenMux.
# Set API_PROVIDER explicitly, or let it auto-detect based on which key is set.

# ─── Option A: NVIDIA NIM (build.nvidia.com) ───────────────────────────────
# Free tier: 40 RPM per key, 1 concurrent, cold start 5-60s, GPU shared.
# Needs heartbeat + hedging + multi-key pool for best performance.

# Single key (40 RPM, 1 concurrent)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Multi-key pool (N × 40 RPM, N concurrent — for parallel sub-agents)
# NVIDIA_API_KEYS=nvapi-key1,nvapi-key2,nvapi-key3,nvapi-key4

# Keys from file (one per line)
# NVIDIA_API_KEYS_FILE=/path/to/keys.txt

# ─── Option B: ZenMux (zenmux.ai) ──────────────────────────────────────────
# Free tier: 10+ concurrent, no cold start, no GPU queue, no rate limit.
# No heartbeat/hedging needed. Recommended for best latency.
# Get your key at https://zenmux.ai
# ZENMUX_API_KEY=sk-ai-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Provider Selection ────────────────────────────────────────────────────
# Auto-detected: if ZENMUX_API_KEY is set (and NVIDIA keys aren't), uses ZenMux.
# To override explicitly:
# API_PROVIDER=nvidia   # force NVIDIA NIM
# API_PROVIDER=zenmux   # force ZenMux

# ─── Model ─────────────────────────────────────────────────────────────────
# Model identifier (provider-specific)
# NVIDIA: moonshotai/kimi-k2.6, minimaxai/minimax-m3, deepseek-ai/deepseek-r1, etc
# ZenMux free: moonshotai/kimi-k2.7-code-free, z-ai/glm-5.2-free, z-ai/glm-4.7-flash-free
# ZenMux paid: z-ai/glm-5.2, moonshotai/kimi-k2.7-code
# MODEL=moonshotai/kimi-k2.6

# Sampling parameters (NVIDIA recommended defaults)
# TEMPERATURE=1.0
# TOP_P=0.95
# MAX_TOKENS=16384

# ─── Effort Level (IDEIA 4) ───────────────────────────────────────────────
# Controls reasoning depth via system prompt (low|medium|high|max)
# low = fast, skip self-validation and auto-tests
# medium = default, balanced
# high = think before every write, enable sub-agents
# max = maximum reasoning, validate before finish_reason
# CLAUDE_KILLER_EFFORT=medium

# ─── Strict Quality Gate (IDEIA 3.4) ───────────────────────────────────────
# When true, blocks finish_reason until tsc + lint pass
# STRICT_MODE=true
# STRICT_GATE_TSC=true
# STRICT_GATE_LINT=true
# STRICT_GATE_MAX_BLOCKS=8
# STRICT_GATE_SKIP_PATTERNS=

# ─── LSP Integration (IDEIA 3.10) ──────────────────────────────────────────
# LSP_ENABLED=true
# LSP_TSSERVER_PATH=
# LSP_PYLSP_PATH=
# LSP_REQUEST_TIMEOUT_MS=5000

# ─── Rate Limiting ─────────────────────────────────────────────────────────
# RATE_LIMIT_RPM=40
# MAX_CONCURRENCY=1
# MAX_HEAL_RETRIES=3

# ─── Context Window ────────────────────────────────────────────────────────
# CONTEXT_WINDOW_TOKENS=128000
# CONTEXT_COMPACT_THRESHOLD=0.75
# CONTEXT_WARN_THRESHOLD=0.6

# ─── Diff Preview ──────────────────────────────────────────────────────────
# DIFF_PREVIEW=true

# ─── Heartbeat (keeps model warm on NVIDIA NIM) ────────────────────────────
# Sends a tiny request every N ms to prevent the model from being unloaded
# from GPU memory (prevents 5-60s cold starts).
# HEARTBEAT_ENABLED=1          # 1=on, 0=off
# HEARTBEAT_INTERVAL_MS=60000  # 1 minute (default)

# ─── Sub-Agent Concurrency ─────────────────────────────────────────────────
# Max number of sub-agents that can run in parallel.
# With 4 keys: 1 main + 2 subs = 3 keys, 1 free for hedging.
# MAX_CONCURRENT_SUB_AGENTS=2

# ─── Tool Auto-Detection (PRIVACY) ─────────────────────────────────────────
# When enabled, searches common installation paths (~/.rokit, ~/.cargo, etc)
# for Roblox/Luau tools. When disabled (default), only checks PATH.
# Set to 1 to enable deep search.
# AUTO_DETECT_TOOLS=0

# ─── Debug ─────────────────────────────────────────────────────────────────
# DEBUG=false
