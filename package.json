{
  "name": "claude-killer",
  "version": "1.0.0",
  "description": "Claude-Killer - CLI agent powered by Kimi K2.6 via NVIDIA NIM API for local code analysis and editing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-killer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --no-warnings=DEP0040 --loader ts-node/esm src/index.ts",
    "start": "npm run build && node --no-warnings=DEP0040 dist/index.js",
    "clean": "rimraf dist",
    "lint": "eslint src/ --no-warn-ignored",
    "lint:report": "eslint src/ --no-warn-ignored --max-warnings 9999 || true",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" --ignore-path .prettierignore",
    "knip": "knip --reporter json || true",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall-searx.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --check --ignore-path .prettierignore"
    ]
  },
  "keywords": [
    "cli",
    "ai",
    "kimi",
    "nvidia",
    "nim",
    "agent",
    "code-assistant"
  ],
  "author": "KimiCode-Local",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "figures": "^6.1.0",
    "ink": "^7.0.6",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.67.0",
    "ora": "^8.1.0",
    "react": "^19.2.7",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/ink": "^0.5.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
